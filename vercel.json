{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd vellum-app && pnpm install --frozen-lockfile",
  "buildCommand": "cd vellum-app && pnpm build",
  "outputDirectory": "vellum-app/.next",
  "ignoreCommand": "git diff HEAD^ HEAD --quiet -- vellum-app/ docs/ vercel.json pnpm-workspace.yaml"
}
