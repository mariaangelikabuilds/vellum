# Vellum environment variables
# Copy to .env.local and fill in. .env.local is gitignored, never commit it.

# === Auth (Clerk) ===
# dashboard.clerk.com → app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Set up later via Clerk dashboard → Webhooks (production)
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app

# === Database (Azure Postgres Flexible Server with AGE + pgvector) ===
# Section 1 used Neon initially; switched to Azure for Apache AGE support.
DATABASE_URL=postgresql://user:pass@host.postgres.database.azure.com:5432/postgres?sslmode=require
# Optional: backup Neon URL for non-graph fallback
NEON_API_KEY=napi_...

# === Anthropic ===
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# === Embeddings (Voyage AI) ===
# dash.voyageai.com → API Keys (1024-dim, voyage-3-large)
VOYAGE_API_KEY=pa-...

# === Web search (Exa) ===
# dashboard.exa.ai → API Keys
EXA_API_KEY=...

# === Workflow queue (Trigger.dev) ===
# cloud.trigger.dev → project → API Keys
TRIGGER_API_KEY=tr_dev_...
TRIGGER_API_URL=https://api.trigger.dev

# === Billing (Stripe, TEST mode for dev) ===
# dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Developers → Webhooks → reveal signing secret (after webhook endpoint exists)
STRIPE_WEBHOOK_SECRET=whsec_...
# Section 5: create products Pro ($19/mo) + Team ($49/seat/mo), copy price IDs
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...

# === Email (Resend) ===
# resend.com → API Keys
RESEND_API_KEY=re_...

# === Observability ===
# braintrust.dev/app → Settings → API Keys
BRAINTRUST_API_KEY=...
# cloud.langfuse.com → Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# Default is EU (cloud.langfuse.com); set to https://us.cloud.langfuse.com if on US region
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# sentry.io → project → Settings → DSN
SENTRY_DSN=https://...@sentry.io/...
# Same value, exposed to client bundle for browser SDK
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# Source map upload (CI only — not for local)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=vellum

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Cloudflare Worker for y-websocket relay (Section 9)
NEXT_PUBLIC_WS_URL=ws://localhost:1234

# === Cloudflare (used by wrangler for Worker deploy, Section 9) ===
CLOUDFLARE_API_TOKEN=cfat_...
CLOUDFLARE_ACCOUNT_ID=...
